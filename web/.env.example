# --- Supabase設定 (Auth & DB) ---
# 開発中: http://127.0.0.1:54321
# 本番: https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabaseの匿名キー (Anon Key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# （注意）必ず127.0.0.1を指定し、localhostは使用しないでください
# 開発中: http://127.0.0.1:3000
# 本番: https://sitecue-web.pages.dev
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# ✨ Hono APIへの接続先
# （注意）開発時のWranglerも127.0.0.1:8787で強制バインドされています
# NEXT_PUBLIC_API_URL=http://127.0.0.1:8787
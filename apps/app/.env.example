# --- Supabase設定 (Auth & DB) ---
# 開発中: http://127.0.0.1:54321
# 本番: https://[project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321

# Supabaseの匿名キー (Anon Key)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- アプリケーションのURL ---
# （注意）必ず127.0.0.1を指定し、localhostは使用しないでください
# Next.jsでのローカル開発 (bun run dev): http://127.0.0.1:3000
# Cloudflareローカルプレビュー (bun run preview): http://127.0.0.1:8787
# 本番環境: 
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# --- APIへの接続先 ---
NEXT_PUBLIC_API_URL=http://127.0.0.1:8787

# ==========================================
# 💡 Cloudflare Workers (Wrangler) 環境変数の注意点
# ==========================================
# ローカルでプレビュー環境（bun run preview）を立ち上げる際、
# Cloudflareの仕様により通常の `.env` は読み込まれません。
# アプリのルートディレクトリに `.dev.vars` というファイルを作成し、
# テストしたい本番用または開発用の環境変数をそちらにもコピペしてください。
# ※ .dev.vars は絶対にコミットしないでください（.gitignore設定済）

---
import Layout from "../layouts/Layout.astro";
---
<Layout>
  <main>
    <!-- Hero Section -->
    <section class="max-w-5xl mx-auto px-6 py-24 md:py-36">
      <div class="grid grid-cols-1 md:grid-cols-2 items-center gap-12 md:gap-16">
        <!-- Text Group -->
        <div class="flex flex-col items-start">
          <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-[#062032] leading-tight">
            Capture your thoughts instantly, right on the spot.
          </h1>
          <p class="mt-4 text-xl md:text-2xl font-medium text-zinc-500">
            Notes that wait exactly where you left them.
          </p>
          <p class="mt-8 text-zinc-500 text-lg leading-relaxed">
            Never worry about where to save or find your notes again. sitecue pins your memos directly to the web pages you are working on. Write immediately, change tabs freely, and let AI weave your thoughts at your Base Camp.
          </p>
          <div class="mt-10">
            <a 
              href="#" 
              class="inline-block bg-[#062032] text-white px-8 py-4 font-bold hover:opacity-90 transition-opacity"
            >
              Get sitecue for Chrome
            </a>
          </div>
        </div>

        <!-- Mockup Image -->
        <div class="flex justify-center">
          <img 
            src="/assets/hero-mock.png" 
            alt="sitecue hero mockup" 
            class="md:w-full h-auto"
          />
        </div>
      </div>
    </section>

    <!-- Why sitecue? Section -->
    <section class="max-w-3xl mx-auto px-6 py-24 md:py-36">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[#062032] leading-tight">
        The internet is full of inspiration, but capturing it is broken. Are you tired of these mental noises?
      </h2>
      
      <div class="mt-24 md:mt-32 flex flex-col space-y-16 md:space-y-24">
        <!-- Item 1 -->
        <div>
          <h3 class="text-xl md:text-2xl font-bold text-[#062032]">
            Where did I save it?
          </h3>
          <p class="mt-4 text-zinc-500 text-lg leading-relaxed">
            Losing focus by opening heavy apps just to write a simple thought.
          </p>
        </div>

        <!-- Item 2 -->
        <div>
          <h3 class="text-xl md:text-2xl font-bold text-[#062032]">
            Where did I see it?
          </h3>
          <p class="mt-4 text-zinc-500 text-lg leading-relaxed">
            Forgetting the original web page or context when you look back at your notes.
          </p>
        </div>

        <!-- Item 3 -->
        <div>
          <h3 class="text-xl md:text-2xl font-bold text-[#062032]">
            Did I already write this?
          </h3>
          <p class="mt-4 text-zinc-500 text-lg leading-relaxed">
            Leaving the exact same memo because your old notes are buried and forgotten.
          </p>
        </div>
      </div>
    </section>

    <!-- The Extension Section -->
    <section class="max-w-5xl mx-auto px-6 py-24 md:py-36">
      <div class="grid grid-cols-1 md:grid-cols-2 items-center gap-12 md:gap-16">
        <!-- Image Column -->
        <div class="flex justify-center">
          <img 
            src="/assets/extension-detail.png" 
            alt="sitecue extension interface" 
            class="md:w-full h-auto"
          />
        </div>

        <!-- Content Column -->
        <div class="flex flex-col items-start">
          <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[#062032] leading-tight">
            The Extension: Your Frictionless Tool on the Ground
          </h2>
          <p class="mt-6 text-zinc-500 text-lg leading-relaxed">
            sitecue lives in your side panel, providing a zero-friction space to capture thoughts without heavy app overhead.
          </p>
          
          <ul class="mt-12 space-y-10">
            <!-- Feature 1 -->
            <li>
              <h3 class="text-xl font-bold text-[#062032]">
                Context-Aware Anchoring
              </h3>
              <p class="mt-2 text-zinc-500 leading-relaxed">
                Tie your notes to an exact URL or an entire domain. They disappear when you leave and surface when you return.
              </p>
            </li>
            <!-- Feature 2 -->
            <li>
              <h3 class="text-xl font-bold text-[#062032]">
                Subtle Reminders
              </h3>
              <p class="mt-2 text-zinc-500 leading-relaxed">
                A minimalist badge on the extension icon gently alerts you to waiting notes on your current page.
              </p>
            </li>
            <!-- Feature 3 -->
            <li>
              <h3 class="text-xl font-bold text-[#062032]">
                Keep it Focused
              </h3>
              <p class="mt-2 text-zinc-500 leading-relaxed">
                Write smoothly in Markdown with beautiful syntax highlighting. Mark items as completed to instantly hide them and clear visual noise.
              </p>
            </li>
            <!-- Feature 4 -->
            <li>
              <h3 class="text-xl font-bold text-[#062032]">
                Quick Links
              </h3>
              <p class="mt-2 text-zinc-500 leading-relaxed">
                Pin essential reference URLs (like GitHub PRs or Figma docs) right onto the page for instant access.
              </p>
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Basecamp Section -->
    <section class="max-w-6xl mx-auto px-6 py-24 md:py-36">
      <!-- Top: Header -->
      <div class="max-w-3xl mx-auto text-center flex flex-col items-center">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[#062032] leading-tight">
          Deep Thinking, Seamless Creation
        </h2>
        <p class="mt-6 text-zinc-500 text-lg leading-relaxed">
          The sitecue Web App (Base Camp) is where your fragmented notes turn into deep creations.
        </p>
      </div>

      <!-- Middle: Large Image -->
      <div class="mt-16 md:mt-24">
        <img 
          src="/assets/basecamp-studio.png" 
          alt="sitecue Base Camp Studio interface" 
          class="w-full h-auto rounded-lg"
        />
      </div>

      <!-- Bottom: Feature Grid -->
      <div class="mt-16 md:mt-24 grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Feature 1 -->
        <div>
          <h3 class="text-xl font-bold text-[#062032]">
            Side-by-Side Context
          </h3>
          <p class="mt-4 text-zinc-500 leading-relaxed">
            Pull up existing notes right next to your editor. Keep your research in sight while you draft.
          </p>
        </div>
        <!-- Feature 2 -->
        <div>
          <h3 class="text-xl font-bold text-[#062032]">
            Co-Think with AI
          </h3>
          <p class="mt-4 text-zinc-500 leading-relaxed">
            Review, rewrite, and refine your text with AI assistance, without losing your original train of thought.
          </p>
        </div>
        <!-- Feature 3 -->
        <div>
          <h3 class="text-xl font-bold text-[#062032]">
            Internal Scratchpad
          </h3>
          <p class="mt-4 text-zinc-500 leading-relaxed">
            Jot down sudden insights on a side memo as you write, keeping your main canvas clean and focused.
          </p>
        </div>
      </div>
    </section>

    <!-- Use Cases Section -->
    <section class="max-w-5xl mx-auto px-6 py-24 md:py-36">
      <!-- Top: Header -->
      <div class="text-center max-w-3xl mx-auto">
        <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[#062032] leading-tight">
          Bring Sitecue to Your Daily Workflow
        </h2>
        <p class="mt-6 text-zinc-500 text-lg leading-relaxed">
          No matter what you do on the web, sitecue keeps you focused on the task in front of you.
        </p>
      </div>

      <!-- Middle: Symbolic Image -->
      <div class="mt-12 md:mt-16">
        <img 
          src="/assets/usecases-symbol.png" 
          alt="sitecue daily workflow visual" 
          class="mx-auto w-full max-w-2xl h-auto"
        />
      </div>

      <!-- Bottom: Use Case Grid -->
      <div class="mt-16 md:mt-24 grid grid-cols-1 md:grid-cols-3 gap-12">
        <!-- Item 1 -->
        <div>
          <h3 class="text-xl font-bold text-[#062032]">
            Anchor Reference Specs
          </h3>
          <p class="mt-4 text-zinc-500 leading-relaxed">
            Drop temporary memos and documentation links exactly where your project lives.
          </p>
        </div>
        <!-- Item 2 -->
        <div>
          <h3 class="text-xl font-bold text-[#062032]">
            Freeze AI Insights
          </h3>
          <p class="mt-4 text-zinc-500 leading-relaxed">
            Save the core takeaways from long articles or AI sessions instantly, without losing your flow.
          </p>
        </div>
        <!-- Item 3 -->
        <div>
          <h3 class="text-xl font-bold text-[#062032]">
            Frictionless Comparison
          </h3>
          <p class="mt-4 text-zinc-500 leading-relaxed">
            Note down pros, cons, and quick ideas on any page, and let them hide when you are done.
          </p>
        </div>
      </div>
    </section>

    <!-- Footer CTA Section -->
    <section class="max-w-3xl mx-auto px-6 py-32 md:py-48 text-center flex flex-col items-center">
      <h2 class="text-3xl md:text-5xl font-bold tracking-tight text-[#062032] leading-tight">
        Ready to travel light across the web?
      </h2>
      <div class="mt-12">
        <a 
          href="#" 
          class="inline-block bg-[#062032] text-white px-8 py-4 font-bold hover:opacity-90 transition-opacity"
        >
          Get sitecue for Chrome
        </a>
      </div>
    </section>
  </main>
</Layout>

